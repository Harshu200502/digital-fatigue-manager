# ── COGNITIVE GUARD: Environment Configuration ──
# Copy this file to .env and adjust values for your environment.

# Flask secret key — used for signing JWTs
SECRET_KEY=guardian_jwt_secret_key_v17_CHANGE_ME

# Database URI (SQLAlchemy)
# Default: SQLite in the backend directory
DATABASE_URI=sqlite:///burnout.db

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=1
